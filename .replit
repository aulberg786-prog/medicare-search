modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
VITE_FIREBASE_APP_ID = "1:293275030223:web:3336fc0091baeb88019dba"
VITE_FIREBASE_AUTH_DOMAIN = "school-c9633.firebaseapp.com"
VITE_FIREBASE_MESSAGING_SENDER_ID = "293275030223"
VITE_FIREBASE_PROJECT_ID = "school-c9633"
VITE_FIREBASE_STORAGE_BUCKET = "school-c9633.firebasestorage.app"
