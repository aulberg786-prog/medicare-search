{
  "buildCommand": "pnpm --filter @workspace/api-spec run codegen && pnpm --filter @workspace/medicare-search run build",
  "outputDirectory": "artifacts/medicare-search/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
